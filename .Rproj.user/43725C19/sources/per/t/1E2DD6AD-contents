## 3. Execution

```{r, eval=FALSE}
set.seed(123)
trainig_ids_df <- data.frame()
all_results_traintest <- data.frame()
all_results_regions <- data.frame()
pb <- progress_bar$new(total = 400)
for (p in c("dormant", "growing")) {
  if (p == "growing") {
    weights <- c(0.18, 0.75, 0.07)
  } else {
    weights <- c(0.7, 0.25, 0.05)
  }
  for (frac in c(0.7, 0.8)) {
    for (i in c(1:100)) {
      res_iter <- xgb_exe(p, frac, weights)
      xgb.save(res_iter$model,
               file.path("new_models_repodc/",
                         paste0(p, "_", frac, "_", i)))
      trainig_ids_df <- rbind(trainig_ids_df,
                              data.frame(Fraction = frac,
                                         Period = p,
                                         Trial = i,
                                         training_ids = res_iter$training_ids))
      all_results_traintest <- rbind(all_results_traintest,
                                     res_iter$eval_all %>%
                                       mutate(Fraction = frac,
                                              Trial = i) %>%
                                       relocate(Fraction, Trial))
      all_results_regions <- rbind(all_results_regions,
                                   res_iter$eval_regions %>%
                                       mutate(Fraction = frac,
                                              Trial = i) %>%
                                       relocate(Fraction, Trial))
      pb$tick()
    }
  }
}
fwrite(trainig_ids_df, "new_models_repodc/training_ids.csv")
fwrite(all_results_traintest, "new_models_repodc/All_Results_TrainTest.csv")
fwrite(all_results_regions, "new_models_repodc/All_Results_Regions.csv")

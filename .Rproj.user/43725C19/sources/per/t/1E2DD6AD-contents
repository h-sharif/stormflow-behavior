## 2. XGBoost Automated Batch Experiment Functions

```{r}
# function to get the performance metrics for both training set and test set
# as well as all samples
calculate_class_metrics <- function(conf_matrix, class_index) {
  true_positives <- conf_matrix[class_index, class_index]
  false_positives <- sum(conf_matrix[, class_index]) - true_positives
  false_negatives <- sum(conf_matrix[class_index, ]) - true_positives
  true_negatives <- sum(conf_matrix) - 
    (true_positives + false_positives + false_negatives)
  
  precision <- true_positives / (true_positives + false_positives)
  recall <- true_positives / (true_positives + false_negatives)
  specificity <- true_negatives / (true_negatives + false_positives)
  f1_score <- 2 * (precision * recall) / (precision + recall)
  
  list(precision = precision, recall = recall,
       specificity = specificity, f1_score = f1_score)
}

eval_metrics_exe <- function(model, dmatrix, obs_labels) {
  # Predict on the test set
  pred <- predict(model, newdata = dmatrix)
  pred_labels <- max.col(matrix(pred,
                                ncol = 3,
                                byrow = TRUE)) - 1
  
  conf_mat <- confusionMatrix(ordered(pred_labels, levels = c(0, 1, 2)),
                              ordered(as.numeric(obs_labels) - 1, 
                                      levels = c(0, 1, 2)))
  # calculate simple performances
  performances_simple <- calculate_class_metrics(conf_mat$table, 1)
  # calculate intermediate performances
  performances_intermediate <- calculate_class_metrics(conf_mat$table, 2)
  # calculate complex performance
  performances_complex <- calculate_class_metrics(conf_mat$table, 3)
  
  # evaluating complex vs non-complex
  testLabels_adj <- ifelse(obs_labels %in% c("simple", "intermediate"),
                           "non-complex", "complex")
  testLabels_adj <- ordered(testLabels_adj,
                            levels = c("non-complex", "complex"))
  pred_labels_adj <- ifelse(pred_labels %in% c(0, 1), 0, 1)
  conf_mat_adj <- confusionMatrix(ordered(pred_labels_adj, levels = c(0, 1)),
                                  ordered(as.numeric(testLabels_adj) - 1,
                                          levels = c(0, 1)))
  performances_noncomplex <- calculate_class_metrics(conf_mat_adj$table, 1) 
  performances_complex_adj <- calculate_class_metrics(conf_mat_adj$table, 2) 
  
  return(
    data.frame(
      behavioral_class = c("simple", "intermediate", "complex", "REV non-complex",
                           "REV complex"),
      num_samples = c(
        summary(obs_labels), summary(testLabels_adj)
      ),
      precision = c(performances_simple$precision,
                    performances_intermediate$precision,
                    performances_complex$precision,
                    performances_noncomplex$precision,
                    performances_complex_adj$precision),
      specificity = c(performances_simple$specificity,
                      performances_intermediate$specificity,
                      performances_complex$specificity,
                      performances_noncomplex$specificity,
                      performances_complex_adj$specificity)
    )
  )
}
```

```{r, eval=FALSE}
xgb_exe <- function(prd, p, manual_weights_vec) {
  names(manual_weights_vec) <- c("simple", "intermediate", "complex")
  params <- list(
    booster = "gbtree",
    objective = "multi:softprob",  # For multi-class classification
    num_class = 3,
    eval_metric = "mlogloss",
    eta = 0.3,
    max_depth = 8,
    subsample = 0.6
    #colsample_bytree = 0.8
  )
  cv.nround <- 100
  cv.nfold <- 5
  early_stopping_rounds <- 20
  
  # XGBoost --------------------------------------------------------------------
  xgdata_regional <- df_xgboost %>%
    dplyr::filter(period == prd) %>%
    dplyr::select(-c(period, Version)) %>%
    rename(Class = behavioral_class)
  
  xgdata <- df_xgboost %>%
    dplyr::filter(period == prd) %>%
    dplyr::select(-c(GCIN, period, Version)) %>%
    rename(Class = behavioral_class)
  
  features <- xgdata %>% dplyr::select(-Class)
  labels <- xgdata$Class
  trainIndex <- createDataPartition(labels, p = p, list = FALSE)
  trainData <- xgdata[trainIndex, ]
  testData <- xgdata[-trainIndex, ]
  # intermediate and complex instances are much larger in number.
  if (!("simple" %in% trainData$Class) | 
      !("simple" %in% testData$Class)) {
    simples <- which(labels == "simple")
    trainIndex1_index <- createDataPartition(simples, p = p, list = FALSE)
    trainIndex1 <- simples[trainIndex1_index]
    nonsimples <- which(labels != "simple")
    trainIndex2_index <- createDataPartition(nonsimples, p = p, list = FALSE)
    trainIndex2 <- nonsimples[trainIndex2_index]
    trainIndex <- c(trainIndex1, trainIndex2)
    trainData <- xgdata[trainIndex, ]
    testData <- xgdata[-trainIndex, ]
  }
  train_ids <- xgdata_regional$GCIN[trainIndex]
  
  trainFeatures <- trainData %>% dplyr::select(-Class)
  trainLabels <- trainData$Class
  testFeatures <- testData %>% dplyr::select(-Class)
  testLabels <- testData$Class
  
  # Applying both Weighting and SMOTE
  synth_obj <- SMOTE(trainFeatures, trainLabels)
  trainLabels <- synth_obj$data$class
  class_counts <- table(trainLabels)
  class_weights <- 1 / class_counts
  class_weights <- class_weights / sum(class_weights)
  instance_weights <- class_weights[as.character(trainLabels)]
  dtrain <- xgb.DMatrix(data = as.matrix(synth_obj$data[, c(1:27)]),
                        label = as.numeric(synth_obj$data$class) - 1,
                        weight = instance_weights)
  dtest <- xgb.DMatrix(data = as.matrix(testFeatures), 
                       label = as.numeric(testLabels) - 1)
  cv <- xgb.cv(
    params = params,
    data = dtrain,
    nrounds = cv.nround,
    nfold = cv.nfold,
    early_stopping_rounds = early_stopping_rounds,
    verbose = FALSE
  )
  best_nrounds <- cv$best_iteration
  final_model <- xgb.train(
    params = params,
    data = dtrain,
    nrounds = best_nrounds,
    watchlist = list(train = dtrain, eval = dtest),
    verbose = FALSE
  )
  
  train_mlogloss <- final_model$evaluation_log$train_mlogloss[best_nrounds]
  eval_mlogloss <- final_model$evaluation_log$eval_mlogloss[best_nrounds]
  
  result_train_df <- bind_rows(
    eval_metrics_exe(final_model, dtrain, trainLabels) %>%
      mutate(Period = prd,
             Set = "Training",
             LogLoss = train_mlogloss) %>%
      relocate(Period, Set),
    eval_metrics_exe(final_model, dtest, testLabels) %>%
      mutate(Period = prd,
             Set = "Testing",
             LogLoss = eval_mlogloss) %>%
      relocate(Period, Set)
  ) %>%
    mutate(
      behavioral_class = ordered(
        behavioral_class,
        levels = c("simple", "intermediate", "complex", "REV non-complex",
                   "REV complex")
      )
    ) %>%
    relocate(LogLoss, .after = specificity)
  
  # get regional labels and features
  result_regions_df <- data.frame()
  for (n in c("NA", "SA", "EU non UK", "UK", "AF", "OC")) {
    ids <- regions_ids$GCIN[which(regions_ids$region == n)]
    dtest_iter <- xgb.DMatrix(
      data = as.matrix(
        xgdata_regional[which(xgdata_regional$GCIN %in% ids)] %>%
          dplyr::select(-c(GCIN, Class))
      ), 
      label = as.numeric(
        xgdata_regional[which(xgdata_regional$GCIN %in% ids)] %>%
          pull(Class)
      ) - 1
    )
    labels_iter <- xgdata_regional[which(xgdata_regional$GCIN %in% ids)] %>%
      pull(Class)
    result_regions_df <- rbind(
      result_regions_df,
      eval_metrics_exe(final_model, dtest_iter, labels_iter) %>%
        mutate(Period = prd, Set = n) %>%
      relocate(Period, Set)
    )
  }
  
  return(
    list(
      training_ids = train_ids,
      model = final_model,
      eval_all = result_train_df,
      eval_regions = result_regions_df
    )
  )
}


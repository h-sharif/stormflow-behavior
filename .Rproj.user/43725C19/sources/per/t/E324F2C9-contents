full_df <- ungauged_df %>%
  mutate(region = as.character(region)) %>%
  dplyr::select(c(region, dormant, growing)) %>%
  pivot_longer(c(2, 3), names_to = "period", values_to = "class") %>%
  drop_na(class) %>%
  count(region, period, class) %>%
  group_by(region, period) %>%
  mutate(
    percent_ungauged = n / sum(n),
    label_ungauged = n
  ) %>%
  ungroup() %>%
  dplyr::filter(
    region %in% c("United States of America",
                  "Latin America & Caribbean",
                  "Europe",
                  "Africa",
                  "Asia",
                  "Oceania")
  ) %>%
  left_join(
    experimental_df %>%
      mutate(region = as.character(region)) %>%
      dplyr::select(c(region, dormant, growing)) %>%
      pivot_longer(c(2, 3), names_to = "period", values_to = "class") %>%
      drop_na(class) %>%
      count(region, period, class) %>%
      group_by(region, period) %>%
      mutate(
        percent_experimental = n / sum(n),
        label_experimental = n
      ) %>%
      ungroup(),
    by = c("region", "period", "class")
  ) %>%
  mutate(
    region = ordered(region,
                     levels = c("United States of America",
                                "Latin America & Caribbean",
                                "Europe",
                                "Africa",
                                "Asia",
                                "Oceania"))
  ) %>%
  dplyr::select(-c(n.x, n.y)) %>%
  pivot_longer(
    cols = c(percent_experimental, label_experimental, percent_ungauged,
             label_ungauged),
    names_to = c("value_type", "group"),
    names_sep = "_",
    values_to = "value"
  ) %>%
  pivot_wider(names_from = value_type, values_from = value) %>%
  mutate(
    group = ifelse(group == "experimental", "Experimental", "Ungauged"),
    group = ordered(group, levels = c("Experimental", 'Ungauged'))
  ) %>%
  mutate(
    class = case_when(
      class == "simple" ~ "s",
      class == "intermediate" ~ "i",
      class == "complex" ~ "c"
    ),
    class = ordered(class, levels = c("s", "i", "c")),
    period = case_when(
      period == "dormant" ~ "Dormant",
      period == "growing" ~ "Growing"
    ),
    period = ordered(period, levels = c("Dormant", "Growing")),
    percent = ifelse(is.na(percent), 0, percent),
    label = ifelse(is.na(label), 0, label)
  )

plt1 <- ggplot(full_df %>%
                 dplyr::filter(period == "Dormant"),
               aes(x = class, y = percent, fill = group)) +
  geom_col(position = position_dodge()) +
  geom_text(aes(label = label), vjust = 0.5, size = 2.5,
            position = position_dodge(width = 0.8)) +
  scale_y_continuous(labels = percent_format(accuracy = 1),
                     limits = c(-0.1, 1)) +
  scale_fill_manual(
    values = c(
      "Experimental" = rgb(0.2, 0.2, 0.8, alpha = 0.8),
      "Ungauged" = rgb(0.8, 0.2, 0.2, alpha = 0.8)
    )
  ) +
  facet_wrap(~ region, scales = "free_x") +
  labs(
    title = "",
    x = "",
    y = "Percentage",
    fill = "Catchment Type"
  ) +
  theme_bw(base_size = 9) +
  theme(
    plot.title =  element_text(size = 11, face = "bold"),
    strip.text = element_text(face = "bold"),
    axis.text.x = element_text(angle = 0, hjust = 1)
  )


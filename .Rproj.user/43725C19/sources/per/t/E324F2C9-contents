ungauged_df <- fread(
  "visualization_data_v2/revised_submission/Ungauged_Catchments_Metadata_and_Attributes.csv"
  ) %>%
  mutate(
    country = ifelse(is.na(country) | country == "", "NA", country),
    continent = countrycode(country, origin = "iso2c",
                            destination = "region")
  ) %>%
  mutate(
    continent = countrycode(country, origin = "iso2c",
                            destination = "continent"),
    continent_regional = countrycode(country, origin = "iso2c",
                                     destination = "region"),
    region = case_when(
      country == "CA" | `Polygon Source` == "BCUB" ~ "Canada (BC) and Salish Sea Region",
      country == "US" & `Polygon Source` != "BCUB" ~ "United States of America",
      continent == "Americas" & continent_regional == "Latin America & Caribbean"
      ~ "Latin America & Caribbean",
      .default = continent,
    ),
    region = ordered(region,
                     levels = c("Canada (BC) and Salish Sea Region",
                                "United States of America",
                                "Latin America & Caribbean",
                                "Europe",
                                "Africa",
                                "Asia",
                                "Oceania")),
    dormant = ordered(dormant_predicted_class,
                      levels = c("simple", "intermediate", "complex")),
    growing = ordered(growing_predicted_class,
                      levels = c("simple", "intermediate", "complex"))

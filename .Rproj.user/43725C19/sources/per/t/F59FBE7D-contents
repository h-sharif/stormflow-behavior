plt_dormant <- check_atts %>%
  dplyr::filter(period == "dormant") %>%
  ggplot(aes(x = att_val_old, y = att_val_new)) +
  geom_abline(slope = 1, intercept = 0) +
  geom_point(color = "blue2", size = 1.4) +
  facet_wrap(vars(att), scales = "free")

summary(check_atts)

ggsave("dormant_check.pdf", plt_dormant, width = 12, height = 12)


plt_growing <- check_atts %>%
  dplyr::filter(period == "growing") %>%
